{
  "name": "create-backend",
  "version": "0.1.0",
  "description": "A one-command npm scaffolding tool that spins up a fully wired backend",
  "main": "src/index.js",
  "bin": {
    "create-backend": "./bin/create-backend.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ bin/",
    "format": "prettier --write src/ bin/",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "backend",
    "scaffolding",
    "cli",
    "express",
    "jwt",
    "auth",
    "api",
    "generator",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "ejs": "^3.1.9",
    "fs-extra": "^11.3.4",
    "inquirer": "^9.2.15",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "@types/sqlite3": "^3.1.11",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  }
}
